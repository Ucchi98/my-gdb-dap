{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "my-gdb-dap",
      "request": "launch",
      "name": "GDB DAP",
      "program": "${workspaceFolder}/build/blink.elf",
      "gdbPath": "/full/path/to/gdb",
      "gdbOpts": [
        "-x=${workspaceFolder}/build/gdbinit/symbols",
        "-x=${workspaceFolder}/build/gdbinit/prefix_map",
        "-x=${workspaceFolder}/build/gdbinit/connect"
      ],
      "ocdPath": "/full/path/to/openocd",
      "ocdOpts": [
        "-f", "relative/path/to/cfg"
      ],
      "ocdAddr": "localhost:3333"
    }
  ]
}
